# API Token - Lấy từ https://sso.ghn.dev/manage-ip?
# Đăng ký tài khoản GHN và lấy token tại phần "Token"
GHN_API_TOKEN=3ebf65db-f33c-11f0-a3d6-dac90fb956b5

# Shop ID - Lấy từ tài khoản GHN
# Tạo shop trên GHN và lấy Shop ID
GHN_SHOP_ID=199104

# Địa chỉ kho hàng mặc định (nơi gửi hàng)
# District ID của kho hàng - Ví dụ: 1542 (Quận 1, TP.HCM)
